# Copy this file to .env and fill in your actual values
# Do NOT commit .env to GitHub

# Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/ecommerce_db

# JWT Configuration
SECRET_KEY=your-very-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App Configuration
APP_NAME=E-Commerce Inventory API
APP_VERSION=1.0.0
DEBUG=True

# Low Stock Alert — Email / SMTP
# Low-stock alerts are emailed to ADMIN_EMAIL after every order
ADMIN_EMAIL=mb80050047@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mb80050047@gmail.com
# Generate App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=your_16_char_app_password
LOW_STOCK_THRESHOLD=5
